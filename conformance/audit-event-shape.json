{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jamjet-labs.github.io/jamjet-policy/audit-event-v1.schema.json",
  "title": "JamJet Audit Event v1",
  "type": "object",
  "required": ["ts", "run_id", "adapter", "host", "tool", "decision", "executed", "schema_version"],
  "properties": {
    "ts": { "type": "string", "format": "date-time" },
    "run_id": { "type": "string", "pattern": "^run_[a-z0-9]+$" },
    "trace_id": { "type": ["string", "null"] },
    "decision_id": { "type": ["string", "null"] },
    "adapter": {
      "type": "string",
      "enum": ["claude-code-hook", "openai-guardrail", "mcp-shim", "python-sdk", "ts-sdk"]
    },
    "host": {
      "type": "string",
      "enum": ["claude-code", "claude-desktop", "cursor", "openai-agents-sdk", "python", "typescript", "custom"]
    },
    "server": { "type": ["string", "null"] },
    "tool": { "type": "string" },
    "args": { "type": "object" },
    "decision": {
      "type": "string",
      "enum": ["ALLOWED", "BLOCKED", "WAITING_FOR_APPROVAL", "APPROVED", "REJECTED", "BUDGET_EXCEEDED", "AUDIT", "ERROR"]
    },
    "rule": { "type": ["string", "null"] },
    "rule_kind": {
      "type": ["string", "null"],
      "enum": ["allow", "block", "require_approval", "audit", null]
    },
    "executed": { "type": "boolean" },
    "policy_version": { "type": "string" },
    "schema_version": { "type": "integer", "const": 1 }
  },
  "additionalProperties": true
}

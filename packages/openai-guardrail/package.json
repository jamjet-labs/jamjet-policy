{
  "name": "@jamjet/openai-guardrail",
  "version": "0.1.1",
  "description": "JamJet policy as an OpenAI Agents SDK tool guardrail. One policy file, every tool call governed.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --shims --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "conformance": "vitest run conformance"
  },
  "dependencies": {
    "@jamjet/cloud": "^0.3.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0"
  },
  "keywords": ["ai-agents", "agent-safety", "openai", "openai-agents-sdk", "guardrail", "ai-governance"],
  "license": "Apache-2.0",
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/jamjet-labs/jamjet-policy.git",
    "directory": "packages/openai-guardrail"
  }
}

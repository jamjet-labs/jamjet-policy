{
  "name": "@jamjet/claude-code-hook",
  "version": "0.1.1",
  "description": "JamJet policy + audit + approval as a Claude Code PreToolUse hook. One policy file, every Claude Code session.",
  "type": "module",
  "bin": {
    "jamjet-hook": "./dist/bin.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/bin.ts --format esm --dts --shims --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "conformance": "vitest run conformance"
  },
  "dependencies": {
    "@jamjet/cloud": "^0.3.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0"
  },
  "keywords": ["ai-agents", "agent-safety", "claude-code", "mcp", "ai-governance", "audit-log"],
  "license": "Apache-2.0",
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "https://github.com/jamjet-labs/jamjet-policy.git",
    "directory": "packages/claude-code-hook"
  }
}
